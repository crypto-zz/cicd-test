contract Erc721Mock is ERC721 {

    constructor(string memory _tokenName, string memory _tokenSymbol) public
        ERC721(_tokenName, _tokenSymbol) {}

    function mint(uint amount) public {
        uint i = totalSupply + 1 ;
        uint limit = totalSupply + amount;
        for(i; i <= limit; i++){
            _mint(msg.sender, i);
        }
    }

    function mintToAccount(address account, uint amount) public {
        uint i = totalSupply + 1;
        uint limit = totalSupply + amount;
        for(i; i <= limit; i++){
            _mint(account, i);
        }
    }
}

